{
  "expo": {
    "name": "RateIt",
    "slug": "rateit-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.yourname.rateit"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.yourname.rateit"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "RateIt accède à ta galerie pour ajouter des images aux éléments.",
          "cameraPermission": "RateIt accède à la caméra pour prendre une photo."
        }
      ],
      [
        "expo-sqlite",
        {
          "enableFTS": false
        }
      ]
    ],
    "scheme": "rateit",
    "experiments": {
      "typedRoutes": true
    }
  }
}
